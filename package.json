{
  "name": "daily-dose",
  "version": "1.15.0",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon --ignore 'logs/' --ignore 'temp/' src/app.js",
    "dev:web": "cd web && npm run dev",
    "dev:watch": "cd web && npx vite build --watch",
    "dev:all": "concurrently --names \"bot,watch,tunnel\" --prefix-colors \"cyan,magenta,yellow\" \"npm run dev\" \"npm run dev:watch\" \"ngrok start --config ./ngrok.yml daily-dose-dev\"",
    "seed": "node scripts/seedOrg.js",
    "org:add-admin": "node scripts/addOrgAdmin.js",
    "super-admin:add": "node scripts/addSuperAdmin.js",
    "manifest:create": "node scripts/updateSlackManifest.js --create",
    "manifest:update": "node scripts/updateSlackManifest.js",
    "manifest:dry-run": "node scripts/updateSlackManifest.js --dry-run",
    "standup:trigger": "node scripts/triggerStandup.js",
    "standup:post": "node scripts/sendManualStandup.js",
    "slack:info": "node scripts/viewSlackTeamInfo.js",
    "team:members": "node scripts/check-team-members.js",
    "team:promote": "node scripts/promoteTeamMember.js",
    "debug:scheduler": "node scripts/debugScheduler.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier --write \"src/**/*.js\" \"scripts/**/*.js\" \"test/**/*.js\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.js\" \"scripts/**/*.js\" \"test/**/*.js\" \"*.{js,json,md}\"",
    "prepare": "husky || true",
    "video:studio": "cd video && npm run video:studio",
    "video:render": "cd video && npm run video:render",
    "video:render:reel": "cd video && npm run video:render:reel",
    "video:vo": "cd video && npm run video:vo",
    "video:music": "cd video && npm run video:music"
  },
  "keywords": [
    "slack",
    "bot",
    "standup",
    "reminder"
  ],
  "author": "Sh Julkar Naen Nahian",
  "license": "MIT",
  "description": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/jnahian/daily-dose"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.15.0",
    "@sentry/node": "^8.55.2",
    "@slack/bolt": "^4.4.0",
    "cookie-parser": "^1.4.7",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.2",
    "node-cron": "^4.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.34.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.3",
    "prisma": "^6.15.0",
    "typescript": "^5.9.2"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "scripts/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "test/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
