{
  "name": "daily-dose",
  "version": "1.6.2",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon --ignore 'logs/' --ignore 'temp/' src/app.js",
    "seed": "node scripts/seedOrg.js",
    "org:add-admin": "node scripts/addOrgAdmin.js",
    "manifest:create": "node scripts/updateSlackManifest.js --create",
    "manifest:update": "node scripts/updateSlackManifest.js",
    "manifest:dry-run": "node scripts/updateSlackManifest.js --dry-run",
    "standup:trigger": "node scripts/triggerStandup.js",
    "standup:post": "node scripts/sendManualStandup.js",
    "slack:info": "node scripts/viewSlackTeamInfo.js",
    "team:members": "node scripts/check-team-members.js",
    "team:promote": "node scripts/promoteTeamMember.js",
    "debug:scheduler": "node scripts/debugScheduler.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier --write \"src/**/*.js\" \"scripts/**/*.js\" \"test/**/*.js\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.js\" \"scripts/**/*.js\" \"test/**/*.js\" \"*.{js,json,md}\""
  },
  "keywords": [
    "slack",
    "bot",
    "standup",
    "reminder"
  ],
  "author": "Sh Julkar Naen Nahian",
  "license": "MIT",
  "description": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/jnahian/daily-dose"
  },
  "dependencies": {
    "@prisma/client": "^6.15.0",
    "@sentry/node": "^8.55.2",
    "@slack/bolt": "^4.4.0",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.2",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "eslint": "^9.34.0",
    "globals": "^15.15.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.3",
    "prisma": "^6.15.0",
    "typescript": "^5.9.2"
  }
}
