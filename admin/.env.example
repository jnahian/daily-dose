# Database (copy from root .env)
DATABASE_URL=postgresql://user:password@host:5432/dbname?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/dbname

# Slack OAuth (same app as bot — find these at api.slack.com/apps > Basic Information)
VITE_SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
VITE_SLACK_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/callback

# Super Admin Access (comma-separated Slack user IDs, e.g. U012AB3CD,U098ZY7WX)
SUPER_ADMIN_SLACK_IDS=

# App
NODE_ENV=development
PORT=4000
