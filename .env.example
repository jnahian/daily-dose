# Slack credentials — see DEPLOYMENT.md for how to obtain these
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=your-app-token
SLACK_USER_TOKEN=xoxp-your-user-token

# Slack OAuth Credentials (required for token refresh)
# Get these from your Slack app's "Basic Information" page
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret

# Database (Supabase / Postgres) — see DEPLOYMENT.md for connection string details
# DATABASE_URL uses the pooled connection (port 6543); DIRECT_URL uses the direct connection (port 5432)
DATABASE_URL=postgresql://user:password@host:6543/dbname?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/dbname

# App
PORT=3000
HOST=localhost
APP_URL=http://localhost:3000
DEFAULT_TIMEZONE=America/New_York
NODE_ENV=development

# Web App Configuration
WEB_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000

# Observability
LOG_LEVEL=info
CONSOLE_LOG_LEVEL=info
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Scripts docs auth (required — the app refuses to start without these)
SCRIPTS_AUTH_USERNAME=
SCRIPTS_AUTH_PASSWORD=

# Slack channel or user ID that receives website contact-form submissions.
# Optional — the contact form returns an error if unset.
CONTACT_SLACK_CHANNEL=

# Admin Panel OAuth
ADMIN_OAUTH_REDIRECT_URI=http://localhost:3000/api/admin/auth/callback

# Slack manifest management (only needed for npm run manifest:* scripts)
# SLACK_CLIENT_ID / SLACK_CLIENT_SECRET are defined above.
SLACK_APP_ID=
SLACK_USER_REFRESH_TOKEN=

# MCP Server — both callback URLs must also be registered in the Slack app's OAuth redirect URLs.
# Manual token web flow (sign in at /mcp-tokens):
MCP_OAUTH_REDIRECT_URI=https://<your-host>/api/mcp/auth/callback
# OAuth 2.1 authorization-server Slack callback (automatic client sign-in):
MCP_OAUTH_AS_REDIRECT_URI=https://<your-host>/api/mcp/oauth/slack/callback
