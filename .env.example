# Slack credentials — see DEPLOYMENT.md for how to obtain these
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=your-app-token
SLACK_USER_TOKEN=xoxp-your-user-token

# Slack OAuth Credentials (required for token refresh)
# Get these from your Slack app's "Basic Information" page
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret

# Database (Supabase / Postgres) — see DEPLOYMENT.md for connection string details
# DATABASE_URL uses the pooled connection (port 6543); DIRECT_URL uses the direct connection (port 5432)
DATABASE_URL=postgresql://user:password@host:6543/dbname?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/dbname

# App
PORT=3000
HOST=localhost
APP_URL=http://localhost:3000
DEFAULT_TIMEZONE=America/New_York
NODE_ENV=development

# Web App Configuration
WEB_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000

# Observability
LOG_LEVEL=info
CONSOLE_LOG_LEVEL=info
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Scripts docs auth (required — the app refuses to start without these)
SCRIPTS_AUTH_USERNAME=
SCRIPTS_AUTH_PASSWORD=

# Slack channel or user ID that receives website contact-form submissions.
# Optional — the contact form returns an error if unset.
CONTACT_SLACK_CHANNEL=

# Admin Panel OAuth
ADMIN_OAUTH_REDIRECT_URI=http://localhost:3000/api/admin/auth/callback

# Slack manifest management (only needed for npm run manifest:* scripts)
# SLACK_CLIENT_ID / SLACK_CLIENT_SECRET are defined above.
SLACK_APP_ID=
SLACK_USER_REFRESH_TOKEN=

# MCP Server — the two Slack OAuth callback URLs are derived from APP_URL
# (<APP_URL>/api/mcp/auth/callback and <APP_URL>/api/mcp/oauth/slack/callback).
# No env var to set, but BOTH must be registered in the Slack app's OAuth redirect URLs.

# Zoho People integration (optional — leave/holiday sync is disabled for an
# org until it has a ZohoCredential row; see `npm run zoho:auth-setup`)
# Self-client app credentials from https://api-console.zoho.<dc>/
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# Only used for the one-time grant-token exchange; must match the redirect
# URI registered for the self-client app.
ZOHO_REDIRECT_URI=http://localhost:3000/auth/zoho/callback
# Data center suffix for both accounts.zoho.<dc> and people.zoho.<dc> —
# "com" (US), "eu", "in", "com.au", "jp", "com.cn". Must match the org's Zoho DC.
ZOHO_DATA_CENTER=com
# Optional cron override for the nightly holiday/leave sync (default: 30 1 * * *)
ZOHO_SYNC_CRON=
